{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run --coverage.enabled=true --coverage.provider=v8 --coverage.include='src/lib/**' --coverage.thresholds.lines=25 --exclude='src/**/*.integration.test.ts'",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "db:migrate": "npx tsx scripts/migrate.ts",
    "db:seed": "npx tsx src/db/seed.ts",
    "db:seed:bulk": "npx tsx src/db/seed.ts --bulk"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@aws-sdk/client-s3": "^3.1025.0",
    "@neondatabase/serverless": "^1.0.2",
    "@netlify/plugin-nextjs": "^5.15.9",
    "@sentry/nextjs": "^10.51.0",
    "@tanstack/react-query": "^5.97.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "next": "16.2.2",
    "next-intl": "^3.23.5",
    "posthog-js": "^1.372.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "resend": "^6.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@types/pg": "^8.11.11",
    "dotenv": "^16.3.1",
    "pg": "^8.20.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
