# Database (Neon PostgreSQL)
# Get your connection string from https://console.neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT Secret
# Generate with: openssl rand -base64 32
JWT_SECRET=your-access-token-secret-min-256-bit

# Email (Resend)
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# From address for transactional emails
RESEND_FROM=noreply@yourdomain.com

# Recipient address for contact form submissions
CONTACT_EMAIL=hello@yourdomain.com

# Rate Limiting (Upstash Redis)
# Get credentials from https://upstash.com
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# File Storage (Cloudflare R2)
# Get credentials from https://dash.cloudflare.com
CLOUDFLARE_R2_BUCKET=neighborhood-hub
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY=your-access-key
CLOUDFLARE_R2_SECRET_KEY=your-secret-key
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Anthropic (AI Chat)
# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# App URL (used for email verification links)
# Production: https://neighborhood-hub.netlify.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog (client)
NEXT_PUBLIC_POSTHOG_KEY=phc_yourKeyHere
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry (error tracking) — optional, set all three to enable
# Get DSN from https://sentry.io → Settings → Projects → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=sntrys_xxxxx
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=neighborhood-hub
