{
  "name": "neighborhood-hub",
  "version": "1.0.0",
  "description": "A multi-platform full-stack app for Bulgarian neighborhoods that enables skill sharing, time swapping, tool lending, food sharing, and community events.",
  "private": true,
  "scripts": {
    "dev:web": "npm run dev --prefix packages/nextjs",
    "dev:mobile": "npm run start --prefix packages/mobile",
    "build:web": "npm run build --prefix packages/nextjs",
    "typecheck:mobile": "npm run --prefix packages/mobile typecheck",
    "smoke:web": "node scripts/smoke-web.mjs",
    "smoke:auth": "node scripts/smoke-auth.mjs",
    "smoke:auth:browser": "node scripts/smoke-auth-browser.mjs",
    "smoke:skill-requests:transitions": "node scripts/smoke-skill-requests-transitions.mjs",
    "smoke:tool-reservations:transitions": "node scripts/smoke-tool-reservations.mjs",
    "test:contract": "node --test scripts/skill-requests-contract.test.mjs scripts/skills-contract.test.mjs"
  },
  "devDependencies": {
    "playwright": "^1.53.1",
    "typescript": "^5.0.0"
  },
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0"
  }
}
